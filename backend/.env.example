# MentorIQ Environment Configuration

# 1. AI API Key (Required)
# Used for the deep-code profile auditing and mentor matching
GROQ_API_KEY="your_groq_api_key_here"

# 2. GitHub Configuration (Optional but Highly Recommended)
# This token drastically increases the amount of data we can pull (GraphQL support)
# Generate from: https://github.com/settings/tokens (Read-only access is fine)
GITHUB_TOKEN="your_github_personal_access_token_here"

# 3. Environment Settings
ENVIRONMENT="development"
# ENVIRONMENT="production"
